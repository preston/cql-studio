{
  "name": "@cqframework/elm-to-sql",
  "version": "0.1.0",
  "description": "Standalone ESM library for transpiling CQL ELM to SQL-on-FHIR queries and generating FHIR MeasureReports",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cql",
    "elm",
    "fhir",
    "sql-on-fhir",
    "measure",
    "hl7",
    "clinical-quality",
    "ecqm"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}
